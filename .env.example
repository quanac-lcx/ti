TZ=Asia/Shanghai

# Optional local Docker infra ports used by `pnpm run dev:infra`
MARIADB_ROOT_PASSWORD=root
MARIADB_DATABASE=luogu_ti
MARIADB_USER=app
MARIADB_PASSWORD=app
MARIADB_PORT=3307

REDIS_PORT=6380

# Production compose ports / public URLs used by `docker compose -f docker-compose.prod.yml`
API_BIND_HOST=0.0.0.0
API_PORT=3000
WEB_BIND_HOST=0.0.0.0
WEB_PORT=5173
# Override when the server cannot reach registry.npmjs.org directly.
NPM_REGISTRY=https://registry.npmmirror.com

# Production public URLs. Leave blank to use the same-origin `/api` proxy fallback.
VITE_API_BASE_URL=
PUBLIC_API_BASE_URL=
WEB_BASE_URL=
CPOAUTH_BASE_URL=https://auth.luogu.me

# Optional S3-compatible CDN upload (used by `docker compose --profile s3-upload`).
S3_UPLOAD_ENABLED=false

# —— 方式一（推荐）：从后台 API 读取配置 ——
# 填写 API 地址和管理员 token，脚本自动从数据库中拉取你已在后台填好的 S3 凭证。
# 使用此方式时无需填写下方 S3_REGION ~ S3_FORCE_PATH_STYLE。
S3_API_BASE_URL=https://api.ti.luogu.me
S3_API_ADMIN_TOKEN=

# —— 方式二：直接在 .env 填写 S3 凭证 ——
# 如果 S3_API_BASE_URL / S3_API_ADMIN_TOKEN 任一为空，脚本会降级使用以下变量。
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PREFIX=
S3_CONCURRENCY=8
S3_FORCE_PATH_STYLE=true

# —— 构建时注入（两种方式都需填写） ——
# 部署时构建前端静态资源时需要，用于让 index.html 中的资源引用指向 CDN。
VITE_CDN_BASE_URL=https://cdn.example.com
S3_CDN_BASE_URL=${VITE_CDN_BASE_URL}
