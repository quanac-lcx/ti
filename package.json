{
  "name": "ti-luogu-me",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20 <25",
    "pnpm": ">=9 <10"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm -C web dev",
    "dev:api": "pnpm -C server dev",
    "dev:infra": "docker compose up -d mariadb redis",
    "dev:infra:down": "docker compose down",
    "build": "pnpm -r build"
  }
}
