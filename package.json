{
  "name": "ti-luogu-me",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20 <25",
    "pnpm": ">=9 <10"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm -C web dev",
    "dev:api": "pnpm -C server dev",
    "dev:infra": "docker compose up -d mariadb redis",
    "dev:infra:down": "docker compose down",
    "build": "pnpm -r build",
    "s3-upload": "node scripts/upload-s3.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "dotenv": "^16.4.7"
  }
}